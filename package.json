{
  "name": "create-saas-app",
  "version": "0.2.0",
  "description": "Scaffold a production-ready Multi-Tenant SaaS Turborepo monorepo in seconds",
  "type": "module",
  "bin": {
    "create-saas-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "saas",
    "boilerplate",
    "turborepo",
    "multi-tenant",
    "scaffold",
    "cli",
    "nextjs",
    "razorpay",
    "drizzle",
    "prisma",
    "bullmq"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vaibhav-Singh2/create-saas-app.git"
  },
  "homepage": "https://github.com/Vaibhav-Singh2/create-saas-app#readme",
  "bugs": {
    "url": "https://github.com/Vaibhav-Singh2/create-saas-app/issues"
  },
  "engines": {
    "node": ">=18"
  }
}